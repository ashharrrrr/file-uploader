<form
    id="upload-form"
    class="flex items-center gap-3"
>

    <label
        for="file-input"
        class="
            inline-flex items-center justify-center
            px-4 py-2
            rounded-xl
            border border-gray-200
            bg-white
            text-sm font-medium
            text-gray-700
            hover:bg-gray-50
            hover:border-gray-300
            cursor-pointer
            transition
        "
    >
        Choose File
    </label>

    <input
        type="file"
        id="file-input"
        class="hidden"
        required
    />

    <button
        type="submit"
        class="
            inline-flex items-center justify-center
            px-4 py-2
            rounded-xl
            bg-blue-600
            text-white
            text-sm font-medium
            hover:bg-blue-700
            active:scale-[0.98]
            transition
        "
    >
        Upload
    </button>

</form>