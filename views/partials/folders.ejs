<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">

    <!-- Header -->
    <div class="mb-6 flex items-center justify-between">

        <div>
            <h2 class="text-xl font-semibold text-gray-900">
                Folders
            </h2>

            <p class="text-sm text-gray-500 mt-1">
                <%= folders.length %> folder(s)
            </p>
        </div>

    </div>


    <!-- Empty State -->
    <% if (folders.length === 0) { %>

        <div class="py-16 text-center">

            <div class="text-5xl mb-4">
                📁
            </div>

            <h3 class="text-lg font-medium text-gray-700">
                No folders yet
            </h3>

            <p class="text-gray-500 mt-2">
                Create your first folder from the sidebar.
            </p>

        </div>

    <% } %>


    <!-- Folder Grid -->
    <% if (folders.length > 0) { %>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

            <% folders.forEach(folder => { %>

                <a
                    href="/folders/<%= folder.id %>"
                    class="group border border-gray-200 rounded-xl p-5 bg-white hover:border-blue-400 hover:shadow-md transition-all duration-200"
                >

                    <div class="flex items-start justify-between">

                        <!-- Left -->
                        <div class="flex items-center gap-3">

                            <div class="text-3xl">
                                📁
                            </div>

                            <div>

                                <h3 class="font-medium text-gray-800 group-hover:text-blue-600 transition">
                                    <%= folder.name %>
                                </h3>

                                <p class="text-xs text-gray-400 mt-1">
                                    Created
                                    <%= new Date(folder.createdAt).toLocaleDateString() %>
                                </p>

                            </div>

                        </div>

                    </div>

                </a>

            <% }) %>

        </div>

    <% } %>

</div>