<nav aria-label="Breadcrumb" class="text-sm text-gray-600">
    <% if (typeof pathString !== 'undefined' && pathString && pathString.length) { %>
        <ol class="flex items-center gap-1">
            <% pathString.forEach((folder, index) => { %>
                <li class="flex items-center">
                    <a href="/folders/<%= folder.id %>" class="text-gray-700 hover:text-blue-600"><%= folder.name %></a>
                    <% if (index !== pathString.length - 1) { %>
                        <svg class="w-4 h-4 text-gray-400 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    <% } %>
                </li>
            <% }) %>
        </ol>
    <% } else { %>
        <div class="text-gray-500">Home</div>
    <% } %>
</nav>