<nav
    aria-label="Breadcrumb"
    class="
      text-sm
      text-gray-600
      overflow-x-auto
      mb-6
    "
>

    <% if (
      pathString &&
      pathString.length
    ) { %>

        <ol
            class="
              flex
              items-center
              gap-1
              whitespace-nowrap
            "
        >

            <% pathString.forEach(
              (folder, index) => {
            %>

                <li
                    class="
                      flex
                      items-center
                    "
                >

                    <a
                        href="
                          /shared/<%= shareToken %>/folder/<%= folder.id %>
                        "
                        class="
                          text-gray-700
                          hover:text-blue-600
                          transition
                          font-medium
                        "
                    >
                        <%= folder.name %>
                    </a>

                    <% if (
                      index !==
                      pathString.length - 1
                    ) { %>

                        <svg
                            class="
                              w-4
                              h-4
                              text-gray-400
                              mx-2
                            "
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 5l7 7-7 7"
                            />
                        </svg>

                    <% } %>

                </li>

            <% }) %>

        </ol>

    <% } %>

</nav>