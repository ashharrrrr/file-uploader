<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">

    <% if (entries.length === 0) { %>

        <div class="py-16 text-center">

            <div class="text-5xl mb-4">
                📁
            </div>

            <h3 class="text-lg font-medium text-gray-700">
                Empty folder
            </h3>

            <p class="text-gray-500 mt-2">
                No files or folders here yet.
            </p>

        </div>

    <% } else { %>

        <div class="space-y-2">

            <% entries.forEach(entry => { %>

                <% if (entry.type === "folder") { %>

                    <a
                        href="/folders/<%= entry.id %>"
                        class="flex items-center justify-between p-4 rounded-lg border border-gray-200 hover:bg-gray-50 hover:border-blue-300 transition"
                    >

                        <div class="flex items-center gap-3">

                            <span class="text-2xl">
                                📁
                            </span>

                            <div>

                                <p class="font-medium text-gray-800">
                                    <%= entry.name %>
                                </p>

                                <p class="text-xs text-gray-400">
                                    Folder
                                </p>

                            </div>

                        </div>

                        <p class="text-xs text-gray-400">
                            <%= new Date(entry.createdAt).toLocaleDateString() %>
                        </p>

                    </a>

                <% } else { %>

                    <div
                        class="flex items-center justify-between p-4 rounded-lg border border-gray-200 hover:bg-gray-50 transition"
                    >

                        <div class="flex items-center gap-3">

                            <span class="text-2xl">
                                📄
                            </span>

                            <div>

                                <p class="font-medium text-gray-800">
                                    <%= entry.name %>
                                </p>

                                <p class="text-xs text-gray-400">
                                    <%= (entry.size / 1024).toFixed(2) %> KB
                                </p>

                            </div>

                        </div>

                        <div class="flex items-center gap-4">

                            <p class="text-xs text-gray-400">
                                <%= new Date(entry.createdAt).toLocaleDateString() %>
                            </p>

                            <a
                                href="/files/download/<%= entry.id %>"
                                class="text-sm text-blue-600 hover:underline"
                            >
                                Download
                            </a>

                        </div>

                    </div>

                <% } %>

            <% }) %>

        </div>

    <% } %>

</div>